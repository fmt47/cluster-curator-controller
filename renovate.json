{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "prHourlyLimit": 5,
  "postUpdateOptions": ["gomodTidy"],
  "enabledManagers": ["gomod", "tekton"],
  "packageRules": [
    {
      "description": "Ignore other Go deps except packages below",
      "matchDatasources": ["go"],
      "enabled": false
    },
    {
      "description": "Group PRs that update Hive APIs as Hive API Synchronization",
      "matchPackageNames": ["github.com/openshift/hive/apis"],
      "groupName": "Hive API Synchronization",
      "commitMessageTopic": "Hive API Synchronization",
      "prPriority": 10,
      "enabled": true
    }
  ]
}
